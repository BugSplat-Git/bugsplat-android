<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_clickable"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:minHeight="84dp"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="16dp">

    <ImageView
        android:id="@+id/cardIcon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        tools:src="@drawable/splat_crash" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/cardTitle"
            style="@style/DemoText.CardTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Crash" />

        <TextView
            android:id="@+id/cardSubtitle"
            style="@style/DemoText.CardSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            tools:text="Native crash · stack + threads + memory" />
    </LinearLayout>
</LinearLayout>
