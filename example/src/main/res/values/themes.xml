<resources>
    <!-- Base application theme. -->
    <style name="Theme.BugsplatExample" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryVariant">@color/brand_navy</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/brand_green</item>
        <item name="colorSecondaryVariant">@color/brand_yellow</item>
        <item name="colorOnSecondary">@color/brand_navy</item>
        <!-- Status bar matches screen background for a seamless look. -->
        <item name="android:statusBarColor">@color/demo_screen_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Background color. -->
        <item name="android:windowBackground">@color/demo_screen_bg</item>
    </style>
</resources>
